[mysqld]
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

# Conservative defaults for Raspberry Pi 5 class hardware.
# Tune upward only after monitoring real production usage.
innodb_buffer_pool_size=512M
innodb_log_file_size=128M
max_connections=100

# Avoid old query cache behavior.
query_cache_type=0

[client]
default-character-set=utf8mb4
