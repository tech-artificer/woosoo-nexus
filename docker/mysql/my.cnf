# NOTE: This file is NOT mounted into the MySQL container.
# Configuration is applied via command-line flags in compose.yaml (mysql.command).
# This file is kept as a reference mirror of those flags.
# To re-activate: add the volume mount back to compose.yaml and remove the command flags.
[mysqld]
innodb_buffer_pool_size = 256M
innodb_log_buffer_size  = 16M
max_connections         = 200
wait_timeout            = 300
interactive_timeout     = 300
innodb_flush_log_at_trx_commit = 2
innodb_flush_method            = O_DIRECT
