# Woosoo Nexus Docker profile.
# Copy to .env.docker, fill secrets, then run:
# powershell -ExecutionPolicy Bypass -File scripts/env/apply-env-profile.ps1 -Profile docker -AllowOverride

PUBLIC_SCHEME=https
PUBLIC_HOST=woosoo.local
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443
TABLET_HTTPS_PORT=4443
APP_NAME=Woosoo
APP_ENV=production
APP_DEBUG=false
APP_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}
ASSET_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}
APP_TIMEZONE=UTC
SCRAMBLE_DOCS_ENABLED_IN_PRODUCTION=false
APP_KEY=base64:REPLACE_WITH_DOCKER_APP_KEY

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=woosoo
DB_USERNAME=woosoo
DB_PASSWORD=change_this_password
DB_ROOT_PASSWORD=rootpassword

# POS Database Configuration
# Set DB_POS_HOST to your POS database hostname or IP
# Example: pos-server.local or 192.168.100.7
DB_POS_HOST=pos-server.local
DB_POS_PORT=3308
DB_POS_DATABASE=krypton_woosoo
DB_POS_USERNAME=woosoo_pos
DB_POS_PASSWORD=password

CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
# Redis Configuration
# REDIS_PASSWORD must be set to a strong secret in production
# Leaving this empty allows unauthenticated access (insecure)
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379
REDIS_CLUSTER=false
REDIS_DB=0

HORIZON_NAME="Woosoo Nexus"
HORIZON_PATH=horizon
HORIZON_PREFIX=woosoo_horizon:
HORIZON_MEMORY_LIMIT=128
SCHEDULER_MEMORY_WARN_MB=192

BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_CACHE_DRIVER=redis
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=default

REVERB_APP_ID=woosoo
REVERB_APP_KEY=replace_with_docker_reverb_key
REVERB_APP_SECRET=replace_with_docker_reverb_secret
REVERB_HOST=0.0.0.0
REVERB_BROADCAST_HOST=${PUBLIC_HOST}
REVERB_PUBLIC_HOST=${PUBLIC_HOST}
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=${PUBLIC_HOST}
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@woosoo.local
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

SESSION_LIFETIME=120
# Session Configuration
# SESSION_ENCRYPT should be true in production for Redis-stored sessions
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=${PUBLIC_HOST}
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=${PUBLIC_HOST},${PUBLIC_HOST}:${PUBLIC_HTTPS_PORT},${PUBLIC_HOST}:${PUBLIC_HTTP_PORT},${PUBLIC_HOST}:${TABLET_HTTPS_PORT}
SANCTUM_COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=${PUBLIC_SCHEME}://${PUBLIC_HOST},http://${PUBLIC_HOST},${PUBLIC_SCHEME}://${PUBLIC_HOST}:${TABLET_HTTPS_PORT}

DEVICE_ALLOW_CLIENT_SUPPLIED_IP=true
DEVICE_ALLOWED_PRIVATE_SUBNETS=192.168.100.0/24

DEVICE_AUTH_PASSCODE=replace_with_docker_passcode
