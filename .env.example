# Woosoo Nexus Laravel Application Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================
# Public Host Configuration
# ============================================
PUBLIC_SCHEME=http
PUBLIC_HOST=127.0.0.1
PUBLIC_HTTP_PORT=8000
PUBLIC_HTTPS_PORT=443
TABLET_HTTPS_PORT=4443

# ============================================
# Application
# ============================================
APP_NAME=Woosoo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
ASSET_URL=
APP_TIMEZONE=UTC

# ============================================
# Database (MySQL)
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=woosoo
DB_USERNAME=root
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ============================================
# POS/Krypton Database (read-only integration)
# ============================================
DB_POS_HOST=127.0.0.1
DB_POS_PORT=3306
DB_POS_DATABASE=krypton_woosoo
DB_POS_USERNAME=pos_readonly
DB_POS_PASSWORD=

# ============================================
# Cache / Queue / Session
# ============================================
CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_CLUSTER=false
REDIS_DB=0

# ============================================
# Broadcasting / Reverb
# ============================================
BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=woosoo
REVERB_APP_KEY=local
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_BROADCAST_HOST=${PUBLIC_HOST}
REVERB_PUBLIC_HOST=${PUBLIC_HOST}
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=${PUBLIC_HOST}
VITE_REVERB_PORT=6001
VITE_REVERB_SCHEME=http

# ============================================
# Monitoring
# ============================================
HORIZON_NAME="Woosoo Nexus"
HORIZON_PATH=horizon
HORIZON_PREFIX=woosoo_horizon:
HORIZON_MEMORY_LIMIT=128
SCHEDULER_MEMORY_WARN_MB=192

PULSE_ENABLED=false
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_CACHE_DRIVER=redis
PULSE_INGEST_DRIVER=redis
PULSE_REDIS_CONNECTION=default

# ============================================
# Authentication / CORS
# ============================================
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=127.0.0.1,127.0.0.1:8000,localhost,localhost:8000
SANCTUM_COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:${TABLET_HTTPS_PORT}

# ============================================
# Device/Tablet
# ============================================
DEVICE_ALLOW_CLIENT_SUPPLIED_IP=false
DEVICE_ALLOWED_PRIVATE_SUBNETS=192.168.100.0/24
DEVICE_AUTH_PASSCODE=

# ============================================
# Mail
# ============================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@woosoo.local
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# Logging / Dev
# ============================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

TELESCOPE_ENABLED=false
SCRAMBLE_DOCS_ENABLED_IN_PRODUCTION=false

# Laravel Boost: expose the Tinker MCP tool (arbitrary PHP execution) to AI
# agents. config/boost.php defaults to env('BOOST_TINKER_TOOL_ENABLED', false),
# i.e. off as a safe fallback; this local template intentionally opts in. Set to
# false to opt out. Local-only — inert when APP_ENV=production.
# See docs/LARAVEL_BOOST_GUIDE.md.
BOOST_TINKER_TOOL_ENABLED=true
