# Krypton ↔ Woosoo BI Platform Configuration
# Copy this to .env and fill in your database details

# Database Connection (MySQL)
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=woosoo
DB_USERNAME=woosoo
DB_PASSWORD=change_this_password

# ============================================
# POS Database (Krypton - Remote Windows MySQL)
# ============================================
# Krypton POS runs on the host-side MySQL endpoint at port 3308.
DB_POS_HOST=192.168.100.2
DB_POS_PORT=3308
DB_POS_DATABASE=krypton_woosoo
DB_POS_USERNAME=root
DB_POS_PASSWORD=

# ============================================
# Redis (Cache, Queues, Sessions)
# ============================================
# IMPORTANT: Use Docker service name 'redis', not 'localhost'
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# Horizon (Queue Dashboard)
# ============================================
HORIZON_NAME="Woosoo Nexus"
HORIZON_PATH=horizon
HORIZON_PREFIX=woosoo_horizon:
HORIZON_MEMORY_LIMIT=128
SCHEDULER_MEMORY_WARN_MB=192

# ============================================
# Pulse (Application Telemetry)
# ============================================
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=redis
PULSE_CACHE_DRIVER=redis
PULSE_REDIS_CONNECTION=default

# ============================================
# Laravel Reverb (WebSockets)
# ============================================
BROADCAST_DRIVER=reverb
REVERB_APP_ID=woosoo
REVERB_APP_KEY=your_reverb_key_here
REVERB_APP_SECRET=your_reverb_secret_here
REVERB_HOST=0.0.0.0
# Reverb broadcast host should match the public host tablets use.
REVERB_BROADCAST_HOST=${PUBLIC_HOST}
REVERB_PUBLIC_HOST=${PUBLIC_HOST}
REVERB_PORT=8080
REVERB_SCHEME=http
# Optional override. Reverb expects hostnames here, not full URLs.
# Example: REVERB_ALLOWED_ORIGINS=${PUBLIC_HOST}

# For frontend WebSocket connection
VITE_REVERB_APP_KEY=your_reverb_key_here
VITE_REVERB_HOST=${PUBLIC_HOST}
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ============================================
# Mail
# ============================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@woosoo.local"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# Logging
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=error

# ============================================
# Session
# ============================================
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ============================================
# Sanctum (API Authentication)
# ============================================
# Tablet PWA is served from https://${PUBLIC_HOST}:${TABLET_HTTPS_PORT}, which is cross-origin by port.
SANCTUM_STATEFUL_DOMAINS=${PUBLIC_HOST},${PUBLIC_HOST}:${PUBLIC_HTTPS_PORT},${PUBLIC_HOST}:${PUBLIC_HTTP_PORT},${PUBLIC_HOST}:${TABLET_HTTPS_PORT}
SANCTUM_COOKIE_DOMAIN=

# ============================================
# Device Auth (Proxy-aware LAN lookup)
# ============================================
DEVICE_ALLOW_CLIENT_SUPPLIED_IP=false
# Comma-separated CIDR allow-list used only when DEVICE_ALLOW_CLIENT_SUPPLIED_IP=true
DEVICE_ALLOWED_PRIVATE_SUBNETS=192.168.100.0/24
# Shared numeric passcode required by all tablets at registration and login
DEVICE_AUTH_PASSCODE=

# ============================================
# CORS
# ============================================
# Tablet PWA origin must be allowed because it is served on port 4443.
CORS_ALLOWED_ORIGINS=${PUBLIC_SCHEME}://${PUBLIC_HOST},http://${PUBLIC_HOST},${PUBLIC_SCHEME}://${PUBLIC_HOST}:${TABLET_HTTPS_PORT}

