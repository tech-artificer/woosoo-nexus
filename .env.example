# Krypton ↔ Woosoo BI Platform Configuration
# Copy this to .env and fill in your database details

# Database Connection (MySQL)
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=bi_readonly
DB_PASSWORD=your_secure_password
DB_NAME=krypton_woosoo

# Alternative: PostgreSQL
# DB_DIALECT=postgresql
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_USER=bi_readonly
# DB_PASSWORD=your_secure_password
# DB_NAME=krypton_woosoo

# Refresh Schedule (cron format)
# Format: minute hour day month weekday
REFRESH_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Report Output
REPORT_OUTPUT_DIR=./reports
LOG_OUTPUT_DIR=./logs

# BI Tool Integrations
TABLEAU_ENABLED=false
TABLEAU_SERVER=your-tableau-server
TABLEAU_USER=bi_user
TABLEAU_PASSWORD=your_password

GRAFANA_ENABLED=true
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your_grafana_api_key

# Drift Thresholds (customize as needed)
AMOUNT_TOLERANCE=0.01
TIME_DELTA_TOLERANCE=300  # seconds
HIGH_DRIFT_ALERT_THRESHOLD=10  # number of issues

# Alerting
ALERT_EMAIL=ops@example.com
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_ENABLED=true

