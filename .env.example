LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# Telescope (Dev only)
# ============================================
TELESCOPE_ENABLED=false

# ============================================
# Scramble API Docs
# ============================================
SCRAMBLE_DOCS_ENABLED_IN_PRODUCTION=false
