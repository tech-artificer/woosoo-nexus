# Woosoo Nexus local Windows profile.
# Copy to .env.local, fill secrets, then run:
# powershell -ExecutionPolicy Bypass -File scripts/env/apply-env-profile.ps1 -Profile local -AllowOverride -AutoRun

PUBLIC_SCHEME=http
PUBLIC_HOST=127.0.0.1
PUBLIC_HTTP_PORT=8000
PUBLIC_HTTPS_PORT=443
TABLET_HTTPS_PORT=4443
APP_NAME=Woosoo
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC
SCRAMBLE_DOCS_ENABLED_IN_PRODUCTION=false
# Laravel Boost: expose the Tinker MCP tool (arbitrary PHP execution) to AI
# agents. Local-only; set to false to opt out per developer.
BOOST_TINKER_TOOL_ENABLED=true
APP_KEY=base64:REPLACE_WITH_LOCAL_APP_KEY

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=woosoo
DB_USERNAME=woosoo
DB_PASSWORD=change_this_password
DB_ROOT_PASSWORD=rootpassword

DB_POS_HOST=192.168.100.7
DB_POS_PORT=3308
DB_POS_DATABASE=krypton_woosoo
DB_POS_USERNAME=woosoo_pos
DB_POS_PASSWORD=password

CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_CLUSTER=false
REDIS_DB=0

HORIZON_NAME="Woosoo Nexus"
HORIZON_PATH=horizon
HORIZON_PREFIX=woosoo_horizon:
HORIZON_MEMORY_LIMIT=128
SCHEDULER_MEMORY_WARN_MB=192

BROADCAST_DRIVER=log
BROADCAST_CONNECTION=log
PULSE_ENABLED=false
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=redis
PULSE_CACHE_DRIVER=redis
PULSE_REDIS_CONNECTION=default

REVERB_APP_ID=woosoo
REVERB_APP_KEY=replace_with_local_reverb_key
REVERB_APP_SECRET=replace_with_local_reverb_secret
REVERB_HOST=127.0.0.1
REVERB_BROADCAST_HOST=127.0.0.1
REVERB_PUBLIC_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@woosoo.local
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=127.0.0.1,127.0.0.1:8000,localhost,localhost:8000
SANCTUM_COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:${TABLET_HTTPS_PORT}

DEVICE_ALLOW_CLIENT_SUPPLIED_IP=false
DEVICE_ALLOWED_PRIVATE_SUBNETS=192.168.100.0/24

DEVICE_AUTH_PASSCODE=replace_with_local_passcode
