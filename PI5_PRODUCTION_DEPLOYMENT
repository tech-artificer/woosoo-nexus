### Phase 5 — nginx Config

**[MANDATORY]**

File: `/etc/nginx/sites-available/woosoo`

```nginx
# HTTP — tablet setup page + CA cert + redirect
server {
    listen 80;
    server_name woosoo.local _;

    location /setup {
        alias /srv/woosoo/setup/;
        index index.html;
    }

    location = /ca.crt {
        alias /srv/woosoo/setup/ca.crt;
        add_header Content-Type application/x-x509-ca-cert;
        add_header Content-Disposition 'attachment; filename="woosoo-ca.crt"';
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — main app
server {
    listen 443 ssl;
    server_name woosoo.local;

    ssl_certificate     /srv/woosoo/certs/woosoo.local.pem;
    ssl_certificate_key /srv/woosoo/certs/woosoo.local-key.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    client_max_body_size 20M;

    # Gzip
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript
               application/json application/javascript application/xml+rss
               application/rss+xml font/truetype font/opentype
               application/vnd.ms-fontobject image/svg+xml;

    # Reverb WebSocket — Pusher protocol uses /app path (NOT /reverb)
    location /app {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    # Laravel backend (PHP-FPM)
    # IMPORTANT: Must include ALL Laravel web routes — any path not listed here
    # falls through to the PWA SPA catch-all and renders the tablet app instead of admin.
    location ~ ^/(api|admin|login|logout|forgot-password|reset-password|dashboard|verify-email|confirm-password|sanctum|broadcasting|up|horizon|pulse|orders|menus|users|roles|permissions|branches|devices|packages|package-configs|tablet-categories|media|reports|monitoring|configuration|reverb|manual|accessibility|service-requests|event-logs)(/|$) {
        root /srv/woosoo/nexus/public;
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME /srv/woosoo/nexus/public/index.php;
        include fastcgi_params;
        fastcgi_hide_header X-Powered-By;
        fastcgi_param HTTPS on;

        fastcgi_param HTTP_X_FORWARDED_PROTO $http_x_forwarded_proto if_not_empty;
        fastcgi_param HTTP_X_FORWARDED_FOR   $http_x_forwarded_for   if_not_empty;
        fastcgi_param HTTP_X_FORWARDED_HOST  $http_x_forwarded_host  if_not_empty;
        fastcgi_param HTTP_X_FORWARDED_PORT  $http_x_forwarded_port  if_not_empty;
        fastcgi_param HTTP_X_CSRF_TOKEN      $http_x_csrf_token      if_not_empty;
        fastcgi_param HTTP_X_XSRF_TOKEN      $http_x_xsrf_token      if_not_empty;
        fastcgi_param HTTP_X_INERTIA         $http_x_inertia          if_not_empty;
        fastcgi_param HTTP_X_INERTIA_VERSION $http_x_inertia_version  if_not_empty;
        fastcgi_param HTTP_X_REQUESTED_WITH  $http_x_requested_with   if_not_empty;
    }

    # Laravel Vite build assets — must be before generic static assets block
    # (regex locations take priority; without this, /build/*.js hits PWA root and 404s)
    location ~* ^/build/ {
        root /srv/woosoo/nexus/public;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Laravel public images — must be before generic static assets block
    # (without this, /images/*.png hits PWA root and 404s)
    location ~* ^/images/ {
        root /srv/woosoo/nexus/public;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Service worker — never cache (PWA update correctness)
    location = /service-worker.js {
        root /srv/woosoo/pwa;
        expires off;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
    }

    # Static assets — aggressive cache
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        root /srv/woosoo/pwa;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # PWA SPA
    root /srv/woosoo/pwa;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Deny hidden files (.env, .git)
    location ~ /\. {
        deny all;
    }
}
```

```bash
sudo ln -s /etc/nginx/sites-available/woosoo /etc/nginx/sites-enabled/woosoo
sudo rm -f /etc/nginx/sites-enabled/default
sudo nginx -t && sudo systemctl reload nginx
```

